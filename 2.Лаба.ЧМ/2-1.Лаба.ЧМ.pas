program ВычислениеВыражений;
var
  a, b, результатA, результатB: Real;

begin
  a := 0.62;
  b := 16.9;
  результатA := a * sqrt(b) / log10(41.3);

  a := 12.47;
  b := 12.52;

  результатB := (a + sqrt(b + sqr(14.82))) / (sqr(sin(0.97)) + sqr(cos(2.68)));

  WriteLn('Результат выражения a: ', результатA:0:10);
  WriteLn('Результат выражения b: ', результатB:0:10);
end.
